<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>aps-environment</key>
	<string>development</string>
	<key>com.apple.developer.aps-environment</key>
	<string>development</string>
	<!--
	  App Attest environment. Use "development" for Xcode/TestFlight builds (paired with
	  ALLOW_DEV_ATTESTATION=true on the proxy) and "production" for App Store builds
	  (ALLOW_DEV_ATTESTATION=false). Without this entitlement DCAppAttestService.isSupported
	  is false even on capable devices.
	-->
	<key>com.apple.developer.devicecheck.appattest-environment</key>
	<string>production</string>
	<key>com.apple.developer.healthkit</key>
	<true/>
	<key>com.apple.developer.healthkit.background-delivery</key>
	<true/>
	<key>com.apple.developer.icloud-services</key>
	<array>
		<string>CloudKit</string>
	</array>
	<key>com.apple.developer.icloud-container-identifiers</key>
	<array>
		<string>iCloud.com.lawlerinnovationsinc-calorie</string>
	</array>
	<!--
	  Force every signed build (Xcode debug, TestFlight, App Store) onto the SAME
	  CloudKit Production environment. Without this, debug builds default to the
	  Development container and TestFlight/App Store installs default to Production
	  — so data written from Xcode is invisible after a TestFlight install (and
	  vice versa). Trade-off: debug runs now mutate real Production data. Deploy
	  schema changes via CloudKit Console (Development → Production) before any
	  schema-affecting change ships to a debug build.
	-->
	<key>com.apple.developer.icloud-container-environment</key>
	<string>Production</string>
	<key>com.apple.developer.ubiquity-kvstore-identifier</key>
	<string>$(TeamIdentifierPrefix)com.lawlerinnovationsinc-calorie</string>
</dict>
</plist>
