// Copy this file to Secrets.xcconfig and fill in the values.
// Secrets.xcconfig is gitignored.
//
// USDA FoodData Central API key (free):
//   https://fdc.nal.usda.gov/api-key-signup.html
//
// PROXY_BASE_URL is the deployed Cloudflare Worker that fronts the Anthropic API.
// The Anthropic API key is set on the worker (`wrangler secret put ANTHROPIC_API_KEY`)
// — never in the client app. See proxy/README.md for setup.
// xcconfig treats `//` as the start of a comment, so we break it up with `$()`
// (an empty variable substitution). The shipped value is plain `https://...`.

USDA_API_KEY = DEMO_KEY
PROXY_BASE_URL = https:/$()/calorie-calc-proxy.YOUR-SUBDOMAIN.workers.dev
